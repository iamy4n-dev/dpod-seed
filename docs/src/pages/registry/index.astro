---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import registryData from '../../data/registry-data.json';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const distros = registryData.distros;
---

<StarlightPage frontmatter={{ title: 'Available Distros', description: 'Browse and pick a dpod-seed distro.' }}>
  {distros.length === 0 ? (
    <p>No distros available yet. Run <code>make generate</code> to populate this page.</p>
  ) : (
    <div class="registry-grid">
      {distros.map((d) => (
        <a class="distro-card" href={`${base}/registry/${d.name}/`}>
          <div class="card-header">
            <span class="distro-name">{d.name}</span>
            <span class:list={['status-badge', d.status === 'stable' ? 'stable' : 'experimental']}>
              {d.status}
            </span>
            <span class="distro-tag">{d.latestTag}</span>
          </div>
          <p class="distro-desc">{d.description}</p>
          {d.packages && d.packages.length > 0 && (
            <div class="pkg-list">
              <strong>Packages:</strong>
              <ul>
                {d.packages.map((p) => <li>{p.name}</li>)}
              </ul>
            </div>
          )}
        </a>
      ))}
    </div>
  )}

  <style>
    .registry-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 1.5rem;
      margin-top: 1.5rem;
    }
    .distro-card {
      border: 1px solid var(--sl-color-gray-5);
      border-radius: 0.5rem;
      padding: 1.25rem;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      text-decoration: none;
      color: inherit;
      cursor: pointer;
      transition: border-color 0.15s, box-shadow 0.15s;
    }
    .distro-card:hover {
      border-color: var(--sl-color-accent);
      box-shadow: 0 0 0 1px var(--sl-color-accent);
    }
    .card-header {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      flex-wrap: wrap;
    }
    .distro-name {
      font-weight: 700;
      font-size: 1rem;
    }
    .distro-tag {
      font-size: 0.75rem;
      color: var(--sl-color-gray-3);
      font-family: var(--sl-font-mono);
    }
    .status-badge {
      font-size: 0.7rem;
      font-weight: 600;
      padding: 0.15rem 0.4rem;
      border-radius: 9999px;
      text-transform: uppercase;
      letter-spacing: 0.03em;
    }
    .status-badge.stable {
      background: var(--sl-color-green-low);
      color: var(--sl-color-green-high);
    }
    .status-badge.experimental {
      background: var(--sl-color-orange-low);
      color: var(--sl-color-orange-high);
    }
    .distro-desc {
      font-size: 0.875rem;
      color: var(--sl-color-gray-2);
      margin: 0;
    }
    .pkg-list {
      font-size: 0.8rem;
    }
    .pkg-list ul {
      margin: 0.25rem 0 0 1rem;
      padding: 0;
    }
    .pkg-list li {
      font-family: var(--sl-font-mono);
    }
  </style>
</StarlightPage>
