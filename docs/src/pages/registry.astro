---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import registryData from '../data/registry-data.json';

const distros = registryData.distros;
---

<StarlightPage frontmatter={{ title: 'Available Distros', description: 'Browse and pick a dpod-seed distro.' }}>
  {distros.length === 0 ? (
    <p>No distros available yet. Run <code>make generate</code> to populate this page.</p>
  ) : (
    <div class="registry-grid">
      {distros.map((d) => (
        <div class="distro-card">
          <div class="card-header">
            <span class="distro-name">{d.name}</span>
            <span class:list={['status-badge', d.status === 'stable' ? 'stable' : 'experimental']}>
              {d.status}
            </span>
            <span class="distro-tag">{d.latestTag}</span>
          </div>
          <p class="distro-desc">{d.description}</p>
          {d.packages && d.packages.length > 0 && (
            <div class="pkg-list">
              <strong>Packages:</strong>
              <ul>
                {d.packages.map((p) => <li>{p}</li>)}
              </ul>
            </div>
          )}
          <button
            class="copy-btn"
            data-snippet={`distro: ${d.name}@${d.latestTag}`}
            onclick="copySnippet(this)"
          >
            Copy config
          </button>
        </div>
      ))}
    </div>
  )}

  <style>
    .registry-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 1.5rem;
      margin-top: 1.5rem;
    }
    .distro-card {
      border: 1px solid var(--sl-color-gray-5);
      border-radius: 0.5rem;
      padding: 1.25rem;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    .card-header {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      flex-wrap: wrap;
    }
    .distro-name {
      font-weight: 700;
      font-size: 1rem;
    }
    .distro-tag {
      font-size: 0.75rem;
      color: var(--sl-color-gray-3);
      font-family: var(--sl-font-mono);
    }
    .status-badge {
      font-size: 0.7rem;
      font-weight: 600;
      padding: 0.15rem 0.4rem;
      border-radius: 9999px;
      text-transform: uppercase;
      letter-spacing: 0.03em;
    }
    .status-badge.stable {
      background: var(--sl-color-green-low);
      color: var(--sl-color-green-high);
    }
    .status-badge.experimental {
      background: var(--sl-color-orange-low);
      color: var(--sl-color-orange-high);
    }
    .distro-desc {
      font-size: 0.875rem;
      color: var(--sl-color-gray-2);
      margin: 0;
    }
    .pkg-list {
      font-size: 0.8rem;
    }
    .pkg-list ul {
      margin: 0.25rem 0 0 1rem;
      padding: 0;
    }
    .pkg-list li {
      font-family: var(--sl-font-mono);
    }
    .copy-btn {
      margin-top: auto;
      padding: 0.4rem 0.75rem;
      border: 1px solid var(--sl-color-accent);
      border-radius: 0.375rem;
      background: transparent;
      color: var(--sl-color-accent);
      cursor: pointer;
      font-size: 0.8rem;
      align-self: flex-start;
      transition: background 0.15s, color 0.15s;
    }
    .copy-btn:hover {
      background: var(--sl-color-accent);
      color: var(--sl-color-white);
    }
  </style>

  <script>
    declare global {
      interface Window { copySnippet: (btn: HTMLButtonElement) => void; }
    }
    window.copySnippet = function(btn) {
      const snippet = btn.dataset.snippet;
      if (!snippet) return;
      navigator.clipboard.writeText(snippet).then(() => {
        const orig = btn.textContent;
        btn.textContent = 'Copied!';
        setTimeout(() => { btn.textContent = orig; }, 2000);
      });
    };
  </script>
</StarlightPage>
